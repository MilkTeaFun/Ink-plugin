{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MilkTeaFun/Ink-plugin/schemas/ink-plugin.schema.json",
  "title": "Ink plugin manifest",
  "description": "Schema for ink-plugin.json. Mirrors ValidateManifest in MilkTeaFun/Ink server/internal/plugins/manifest.go.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "pluginKey",
    "name",
    "version",
    "runtime",
    "fetchPolicy",
    "entrypoints"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "kind": {
      "type": "string",
      "const": "source"
    },
    "pluginKey": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Lowercase letters, digits, and dashes. Must be unique across the Ink instance."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["node", "python"]
        }
      }
    },
    "fetchPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "minutes"],
      "properties": {
        "type": {
          "type": "string",
          "const": "fixed_interval"
        },
        "minutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validate", "fetch"],
      "properties": {
        "validate": { "$ref": "#/$defs/commandSpec" },
        "fetch": { "$ref": "#/$defs/commandSpec" }
      }
    },
    "workspaceConfigSchema": {
      "type": "array",
      "items": { "$ref": "#/$defs/fieldSpec" }
    }
  },
  "$defs": {
    "commandSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fieldSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "type"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^\\S+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["text", "secret", "textarea", "url", "number", "select", "checkbox"]
        },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "defaultValue": {},
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "value": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "select" } },
            "required": ["type"]
          },
          "then": {
            "required": ["options"],
            "properties": {
              "options": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
